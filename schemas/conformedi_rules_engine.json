{
  "version": "2026.1.0",
  "description": "Référentiel ConformEDI des règles métier de calcul des variables de diagnostic à partir des variables atomiques extraites. Format évaluable de manière déterministe (cf. evaluate_rules.js).",
  "evaluation_semantics": {
    "rule_format": "Chaque variable de diagnostic possède une liste ordonnée de règles. La première règle dont la condition est satisfaite donne le résultat. Si aucune ne match, on prend `default`.",
    "condition_keys": {
      "object_literal": "Un objet {var1: val1, var2: val2} est un AND implicite : toutes les variables doivent être strictement égales aux valeurs.",
      "or": "{or: [{a: 1}, {b: 2}]} = OU logique entre les sous-conditions.",
      "and": "{and: [...]} = ET logique (équivalent à objet littéral mais explicite).",
      "any_of_at_least": "{any_of_at_least: {vars: [['a', true], ['b', true]], min: 1}} = au moins N variables ont leur valeur cible."
    },
    "null_handling": "Une variable null ne matche aucune condition stricte. Si toutes les règles échouent à cause de nulls, la diagnostic_variable prend la valeur 'À_VALIDER' (jamais null en sortie).",
    "block_inactive_behavior": "Si un bloc a active_when et la condition n'est pas satisfaite, toutes ses diagnostic_variables retournent 'N/A' automatiquement."
  },

  "blocks": {

